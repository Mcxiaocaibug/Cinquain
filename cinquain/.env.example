CINQUAIN_STACK_NAME=cinquain
CINQUAIN_BUILD_LOCALLY=0
CINQUAIN_HOMESERVER_IMAGE=ghcr.io/mcxiaocaibug/cinquain:main
CINQUAIN_SERVER_NAME=matrix.example.com
CINQUAIN_BOOTSTRAP_SECRET=
CINQUAIN_ACME_EMAIL=admin@example.com
CINQUAIN_SUPPORT_EMAIL=admin@example.com

# Optional build mirrors for hosts that cannot reach the default package sources reliably.
CINQUAIN_DEBIAN_APT_MIRROR=http://deb.debian.org/debian
CINQUAIN_DEBIAN_SECURITY_APT_MIRROR=http://deb.debian.org/debian-security
CINQUAIN_LLVM_APT_MIRROR=https://apt.llvm.org
CINQUAIN_RUSTUP_DIST_SERVER=https://static.rust-lang.org
CINQUAIN_RUSTUP_UPDATE_ROOT=https://static.rust-lang.org/rustup
