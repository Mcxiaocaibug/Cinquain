{% extends "_layout.html.j2" %}

{%- block head -%}
<link rel="stylesheet" href="/_continuwuity/resources/error.css">
{%- endblock -%}

{%- block title -%}
Request Error
{%- endblock -%}

{%- block content -%}
<div class="panel error-frame">
    <div class="error-code">{{ status }}</div>
    <h1>
        {% if status == StatusCode::NOT_FOUND %}
        This page does not exist.
        {% else if status == StatusCode::INTERNAL_SERVER_ERROR %}
        The homeserver hit an internal error.
        {% else %}
        The request could not be processed.
        {% endif %}
    </h1>

    {% if status == StatusCode::NOT_FOUND %}
    <p>Return to the main runtime page or open the support page for the expected operator routes.</p>
    {% else %}
    <p>Inspect the homeserver logs, then use the support page to verify the expected runtime endpoints.</p>
    {% endif %}

    {% if status == StatusCode::INTERNAL_SERVER_ERROR %}
    <p>If this is reproducible, report it with the relevant logs and deployment details.</p>
    {% endif %}

    <div class="error-actions">
        <a href="/">Open runtime home</a>
        <a href="/support">Open support page</a>
    </div>

    <pre><code>{{ error }}</code></pre>
</div>

{%- endblock -%}
